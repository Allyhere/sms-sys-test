# ─── Postgres ───
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sms
POSTGRES_PASSWORD=smspassword
POSTGRES_DB=sms_system

# ─── Backend (API) ───
PORT=3000
TWILIO_MODE=mock
MOCK_TWILIO_URL=http://mock-twilio:4000
TWILIO_AUTH_TOKEN=mock-auth-token-for-local-dev
TWILIO_ACCOUNT_SID=AC00000000000000000000000000000000
TWILIO_FROM_NUMBER=+15550000000
TWILIO_VALIDATE_SIGNATURE=false  # Set to true in production

# ─── Redis / BullMQ ───
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_CONCURRENCY=5

# ─── Rate Limiting ───
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ─── Circuit Breaker ───
CB_TIMEOUT=10000
CB_ERROR_THRESHOLD=50
CB_RESET_TIMEOUT=30000

# ─── Mock Twilio ───
MOCK_PORT=4000
WEBHOOK_URL=http://api:3000/api/webhooks/twilio
WEBHOOK_STATUS_URL=http://api:3000/api/webhooks/twilio/status
DEFAULT_TO_NUMBER=+15550000000
MOCK_DELAY_MS=100

# ─── Frontend ───
VITE_API_URL=http://localhost:3000
